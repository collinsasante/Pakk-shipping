# ============================================================
# PAKKMAXX - Environment Variables
# Copy this file to .env.local and fill in your values
# ============================================================

# ---- AIRTABLE ----
AIRTABLE_API_KEY=patXXXXXXXXXXXXXX.XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
AIRTABLE_BASE_ID=appXXXXXXXXXXXXXX

# ---- FIREBASE (Client-side) ----
NEXT_PUBLIC_FIREBASE_API_KEY=AIzaSyXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your-project-id
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=123456789012
NEXT_PUBLIC_FIREBASE_APP_ID=1:123456789012:web:XXXXXXXXXXXXXXXXXXXXXXXX

# ---- FIREBASE ADMIN (Server-side) ----
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your-project.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nXXXXXXXXX\n-----END PRIVATE KEY-----\n"

# ---- APP ----
NEXT_PUBLIC_APP_URL=http://localhost:3000
APP_SECRET=your-super-secret-jwt-key-change-this-in-production

# ---- WHATSAPP (via Airtable Automation - see docs) ----
# Airtable automations handle WhatsApp - configure in Airtable UI
# Optionally add WhatsApp Business API direct integration:
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_VERIFY_TOKEN=
